# --- Backend environment (template) ---
# Copy to `.env` and adjust for your machine.

# PostgreSQL connection string.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/luxe_support

# Secret used to sign JWT access tokens. Use a long random value in production.
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# HTTP + WebSocket port for the NestJS server.
PORT=3001

# Origin allowed for CORS / Socket.IO (the Next.js frontend).
CORS_ORIGIN=http://localhost:3000
